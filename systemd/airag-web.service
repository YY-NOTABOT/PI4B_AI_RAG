[Unit]
Description=AI RAG medical guidance web service
After=network-online.target neo4j.service
Wants=network-online.target

[Service]
Type=simple
User=yy-notabot
WorkingDirectory=/home/yy-notabot/AI_RAG
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/yy-notabot/AI_RAG/.venv/bin/python -m uvicorn app:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
